{
  "name": "mandir",
  "private": true,
  "scripts": {
    "start": "bundle exec jekyll serve",
    "start:https": "bundle exec jekyll serve --ssl-key .ssl/key.pem --ssl-cert .ssl/cert.pem",
    "test": "npm run test:release",
    "test:mock": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:e2e": "npx playwright test --config playwright.e2e.config.js",
    "test:e2e:ui": "npx playwright test --config playwright.e2e.config.js --ui",
    "test:rotation": "npx playwright test --config playwright.rotation.config.js",
    "test:release": "npm run test:e2e && npm run test:rotation"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
